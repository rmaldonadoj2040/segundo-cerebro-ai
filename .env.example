# Copy this file to .env and fill in your values.
# The app reads these variables at runtime; config.toml provides defaults.

# ── LLM connection ────────────────────────────────────────────────────────────
# Your OpenAI (or compatible) API key.
# Set to "mock" to run the full pipeline without any API calls.
OPENAI_API_KEY=mock

# Model name — must be available on your API endpoint.
LLM_MODEL=gpt-4o-mini

# Leave blank to use OpenAI's default endpoint.
# Override for local servers (e.g. Ollama, LM Studio):
# LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=
