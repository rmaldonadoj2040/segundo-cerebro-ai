# Copy this file to .env.
# Shell environment variables override both this file and config.toml.

# LLM connection.
# Use "mock" for a zero-cost local demo with deterministic stub responses.
OPENAI_API_KEY=mock

# Model name. Must be available on your API endpoint.
LLM_MODEL=gpt-4o-mini

# Leave blank to use OpenAI's default endpoint.
# Override for local servers (e.g. Ollama, LM Studio):
# LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=

# Optional path overrides for demos, CI, or isolated test runs.
# Relative paths are resolved from the repository root.
# LLMKS_CAPTURES_DIR=data/capturas
# LLMKS_KNOWLEDGE_MAP_DIR=vault
# LLMKS_OUTPUTS_DIR=outputs
# LLMKS_ARCHIVE_ORIGINALS_DIR=data/archivo/originales
# LLMKS_ARCHIVE_NORMALIZED_DIR=data/archivo/normalizado
